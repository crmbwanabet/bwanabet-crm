{
  "name": "bwanabet-crm",
  "private": true,
  "version": "0.0.0",
  "description": "BwanaBet manager CRM — vanilla JS single-file app",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test \"tests/*.test.js\"",
    "build:css": "tailwindcss -i ./tailwind.in.css -o ./assets/css/tailwind.css --minify",
    "dev:css": "tailwindcss -i ./tailwind.in.css -o ./assets/css/tailwind.css --watch",
    "build": "npm run build:css"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
